@echo off
REM ============================================================
REM  spotify_credentials.bat.example
REM
REM  SETUP INSTRUCTIONS:
REM  1. Copy this file and rename it to: spotify_credentials.bat
REM  2. Replace the placeholder values below with your credentials
REM     from https://developer.spotify.com/dashboard
REM
REM  Redirect URI to register in the dashboard:
REM    http://127.0.0.1:8888/callback
REM    (http://localhost:8888/callback does NOT work)
REM ============================================================

set SPOTIFY_CLIENT_ID=your_client_id_here
set SPOTIFY_CLIENT_SECRET=your_client_secret_here
